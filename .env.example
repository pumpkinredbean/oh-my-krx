KIS_APP_KEY=your_real_app_key
KIS_APP_SECRET=your_real_app_secret
KIS_HTS_ID=your_hts_id
KIS_REST_URL=https://openapi.koreainvestment.com:9443
KIS_WS_URL=ws://ops.koreainvestment.com:21000
# KSXT websocket proxy policy. See ksxt/clients/kis/transport.py _resolve_kis_websocket_proxy.
# values: unset / direct = direct connection (default),
#         auto = inherit HTTP(S)_PROXY/NO_PROXY from env,
#         <url> = explicit proxy URL.
KSXT_KIS_WS_PROXY=direct
